  dialoguePanel: {fileID: 223816332}
  dialogueText: {fileID: 2081819620}
  nextButton: {fileID: 1849154382}
  dialogueLines:
  - "Khoan\u2026 \u0111\u1EEBng b\u1EAFn n\u1EEFa\u2026"
  - "Ch\xFAng \u0111i r\u1ED3i ph\u1EA3i kh\xF4ng\u2026?"
  - "T\xF4i t\u01B0\u1EDFng m\xECnh ch\u1EBFt ch\u1EAFc r\u1ED3i\u2026"
  - "B\u1ECDn ch\xFAng xu\u1EA5t hi\u1EC7n t\u1EEB trong r\u1EEBng\u2026 qu\xE1 nhi\u1EC1u\u2026"
  - "\xD4ng b\u1ECB c\u1EAFn \xE0?"
  - "Kh\xF4ng\u2026 ch\u1EC9 b\u1ECB c\xE0o th\xF4i\u2026"
  - "C\xF2n th\u1EE9 kinh kh\u1EE7ng h\u01A1n \u0111\xE1m v\u1EEBa n\xE3y n\u1EEFa..."
  - "L\xE0 sao?"
  - "T\xF4i c\xF3 linh c\u1EA3m th\u1EE9 \u0111\xF3 s\u1EAFp xu\u1EA5t hi\u1EC7n
    r\u1ED3i."
  - "Nhanh..H\xE3y gi\xFAp t\xF4i \u0111\u1EE9ng d\u1EADy!"
  useSpeakerLabels: 1
  dialogueSpeakers:
  - Jake
  - Jake
  - Jake
  - Jake
  - John
  - Jake
  - Jake
  - John
  - Jake
  - Jake
  dialogueLines2:
  - "C\u1EA3m \u01A1n \u0111\xE3 c\u1EE9u t\xF4i..."
  - "B\u1ECDn ch\xFAng \u1EDF \u0111\xE2u m\xE0 nhi\u1EC1u v\u1EADy?"
  - "T\xF4i ngh\u0129 th\u1EE9 \u0111\xF3 s\u1EAFp xu\u1EA5t hi\u1EC7n r\u1ED3i..."
  - "Gi\xFAp t\xF4i \u0111\u1EE9ng d\u1EADy n\xE0o!"
